ocs":{},"df":0,"o":{"docs":{},"df":0,"j":{"docs":{},"df":0,"e":{"docs":{},"df":0,"c":{"docs":{},"df":0,"t":{"docs":{"https://drewkerby.dev/projects/":{"tf":1.0}},"df":1}}}}}}},"r":{"docs":{},"df":0,"a":{"docs":{},"df":0,"n":{"docs":{},"df":0,"d":{"docs":{},"df":0,"o":{"docs":{},"df":0,"m":{"docs":{"https://drewkerby.dev/talks/adventures-in-onchain-randomness/":{"tf":1.0}},"df":1}}}}},"e":{"docs":{},"df":0,"a":{"docs":{},"df":0,"d":{"docs":{"https://drewkerby.dev/books/":{"tf":1.0}},"df":1}}}},"s":{"docs":{},"df":0,"e":{"docs":{},"df":0,"e":{"docs":{"https://drewkerby.dev/":{"tf":1.0}},"df":1}},"i":{"docs":{},"df":0,"m":{"docs":{},"df":0,"i":{"docs":{},"df":0,"l":{"docs":{},"df":0,"a":{"docs":{},"df":0,"r":{"docs":{"https://drewkerby.dev/projects/project-1/":{"tf":1.0}},"df":1}}}}}}},"t":{"docs":{},"df":0,"a":{"docs":{},"df":0,"l":{"docs":{},"df":0,"k":{"docs":{"https://drewkerby.dev/talks/":{"tf":1.0}},"df":1}}}},"u":{"docs":{},"df":0,"p":{"docs":{"https://drewkerby.dev/posts/markdown/":{"tf":1.0}},"df":1}}}}},"documentStore":{"save":true,"docs":{"https://drewkerby.dev/":{"body":"I'm Drew, a software engineer from the United States with a background spanning full-stack web and mobile development, Web3/DeFi protocols, and embedded systems. I'm currently building HODL Bonds, an innovative DeFi protocol combining algorithmic trading strategies with the transparency and self-custody of the blockchain.\nThese days I'm focused on EVM smart contracts, systems-level programming in Rust, and embedded firmware, building projects like a CHIP-8 emulator or a RISC-V processor using the ULX3S FPGA dev board. I'm passionate about retro consoles, low-level computing, and bridging the gap between software and hardware.\nWhen I'm not coding, I'm running, swinging a kettlebell, or learning Greek (Γεια σου).","description":"","id":"https://drewkerby.dev/","path":"/","title":"Good to see you."},"https://drewkerby.dev/books/":{"body":"","description":"","id":"https://drewkerby.dev/books/","path":"/books/","title":"Currently Reading"},"https://drewkerby.dev/posts/":{"body":"","description":"","id":"https://drewkerby.dev/posts/","path":"/posts/","title":"Posts"},"https://drewkerby.dev/posts/markdown/":{"body":"The Bring Up\nThere's a process in the hardware world called \"bringing up the board\", where you install all of the software and drivers needed to communicate with the board, plug it in, and flash it with a test bitstream to make sure both the board and your toolchain works as expected. This can include installing dozens of gigabytes of proprietary vendor tooling if it's a mainstream FPGA, and troubleshooting driver issues to get the board to connect on the system that you're using. Usually it's just flashing a single LED on the board.\nThis is me bringing up a small corner of the internet to share what I'm working on, things I've built, and my thoughts about software development and tech in general. I hope its more exciting that a single flashing LED.\nStay tuned.\nDrew","description":"","id":"https://drewkerby.dev/posts/markdown/","path":"/posts/markdown/","title":"The Bring Up"},"https://drewkerby.dev/projects/":{"body":"","description":"","id":"https://drewkerby.dev/projects/","path":"/projects/","title":"Projects"},"https://drewkerby.dev/projects/project-1/":{"body":"","description":"Detects the similarity between projects using Levenshtein distance.","id":"https://drewkerby.dev/projects/project-1/","path":"/projects/project-1/","title":"Code Similarity Detector"},"https://drewkerby.dev/talks/":{"body":"","description":"","id":"https://drewkerby.dev/talks/","path":"/talks/","title":"Talks"},"https://drewkerby.dev/talks/adventures-in-onchain-randomness/":{"body":"A blockchain gaming-focused discussion on how to generate a secure random number inside of a smart contract running on the EVM.","description":"We discuss the lessons learned in implementing secure, on-chain randomness.","id":"https://drewkerby.dev/talks/adventures-in-onchain-randomness/","path":"/talks/adventures-in-onchain-randomness/","title":"Adventures in On-Chain Randomness"}},"docInfo":{"https://drewkerby.dev/":{"body":78,"description":0,"path":0,"title":2},"https://drewkerby.dev/books/":{"body":0,"description":0,"path":1,"title":2},"https://drewkerby.dev/posts/":{"body":0,"description":0,"path":1,"title":1},"https://drewkerby.dev/posts/markdown/":{"body":76,"description":0,"path":2,"title":2},"https://drewkerby.dev/projects/":{"body":0,"description":0,"path":1,"title":1},"https://drewkerby.dev/projects/project-1/":{"body":0,"description":7,"path":3,"title":3},"https://drewkerby.dev/talks/":{"body":0,"description":0,"path":1,"title":1},"https://drewkerby.dev/talks/adventures-in-onchain-randomness/":{"body":13,"description":7,"path":4,"title":3}},"length":8},"lang":"English"}